# ============================================================
# HORIZON CORE – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Port for the backend API server
SERVER_PORT=8080

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=horizon
DB_PASSWORD=horizon_secure_pass
DB_NAME=horizon

# ============================================================
# BEACONCHAIN EXPLORER API
# ============================================================
# URL of the beaconchain explorer (gobitfly/eth2-beaconchain-explorer)
EXPLORER_URL=http://explorer:3500

# ============================================================
# GITHUB WEBHOOK
# ============================================================
# Secret for validating GitHub webhook payloads
# Must match the secret configured in your GitHub webhook settings
WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Personal Access Token (needs repo:status scope)
# Used to set commit statuses in CI/CD
GITHUB_TOKEN=your_github_token_here

# Port for the webhook server (if running separately)
WEBHOOK_PORT=8080

# ============================================================
# OPTIONAL – For production deployment
# ============================================================
# DOMAIN=beaconchain.us
# NODE_ENV=production
