<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>افق فرشته · پنل اجرای واقعی</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family:'Inter',sans-serif;
  background:radial-gradient(circle at 10% 20%, #0a0f1e, #03050a);
  color:#eef2ff;
  padding:0.8rem;
  min-height:100vh;
}
.container { max-width:1200px; margin:0 auto; }
.glass {
  background:rgba(12,18,28,0.85);
  backdrop-filter:blur(12px);
  border-radius:1.8rem;
  border:1px solid rgba(79,158,255,0.2);
  padding:1rem 1.2rem;
  margin-bottom:1rem;
}
.flex { display:flex; flex-wrap:wrap; gap:0.8rem; align-items:center; justify-content:space-between; }
.badge {
  background:rgba(79,158,255,0.15);
  border:1px solid #4f9eff44;
  padding:0.15rem 0.8rem;
  border-radius:60px;
  font-size:0.65rem;
  display:inline-block;
}
.badge-green { background:rgba(74,222,128,0.15); border-color:#4ade8055; color:#4ade80; }
.badge-gold { background:rgba(251,191,36,0.15); border-color:#facc1555; color:#facc15; }
.btn {
  background:#4f9eff;
  border:none;
  padding:0.4rem 1.2rem;
  border-radius:2rem;
  font-weight:600;
  color:#0a0f1e;
  cursor:pointer;
  transition:0.2s;
  font-size:0.75rem;
}
.btn:hover { background:#c084fc; transform:scale(1.02); }
.btn-outline { background:transparent; border:1px solid #4f9eff55; color:#eef2ff; }
.btn-outline:hover { background:#4f9eff22; }
.btn-success { background:#4ade80; color:#0a0f1e; }
.btn-success:hover { background:#22c55e; }
.btn-danger { background:#f87171; color:#0a0f1e; }
.btn-danger:hover { background:#ef4444; }
.grid-4 {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));
  gap:0.8rem;
}
.stat-card {
  background:rgba(20,24,36,0.5);
  border-radius:1rem;
  padding:0.6rem 1rem;
  border:1px solid rgba(255,255,255,0.05);
  text-align:center;
}
.stat-card .num { font-size:1.4rem; font-weight:800; color:#4f9eff; }
.stat-card .label { font-size:0.6rem; color:#8fa2dc; }
.chat-box {
  background:#0f172a;
  border-radius:1rem;
  padding:0.6rem 0.8rem;
  max-height:200px;
  overflow-y:auto;
  border:1px solid #1e2a44;
  display:flex;
  flex-direction:column;
  gap:0.3rem;
}
.chat-box .msg {
  padding:0.3rem 0.7rem;
  border-radius:0.8rem;
  max-width:90%;
  font-size:0.8rem;
  line-height:1.4;
}
.chat-box .user { align-self:flex-end; background:#4f9eff; color:#0a0f1e; }
.chat-box .ai { align-self:flex-start; background:rgba(255,255,255,0.06); color:#e5e7f0; border:1px solid #2a3a5a; }
.chat-row { display:flex; gap:0.4rem; margin-top:0.4rem; }
.chat-row input {
  flex:1;
  background:#0f172a;
  border:1px solid #2a3a5a;
  border-radius:2rem;
  padding:0.4rem 0.8rem;
  color:#eef2ff;
  outline:none;
  font-size:0.8rem;
}
.chat-row input:focus { border-color:#4f9eff; }
.chat-row button {
  background:#4f9eff;
  border:none;
  border-radius:2rem;
  padding:0 1rem;
  font-weight:600;
  color:#0a0f1e;
  cursor:pointer;
}
.chat-row button:hover { background:#c084fc; }
.log-box {
  background:#0f172a;
  border-radius:1rem;
  padding:0.5rem 0.8rem;
  max-height:120px;
  overflow-y:auto;
  font-family:monospace;
  font-size:0.65rem;
  border:1px solid #1e2a44;
}
.log-box .log { padding:0.1rem 0; border-bottom:1px solid #1a2238; color:#94a3b8; }
.log-box .log .t { color:#4f9eff; margin-left:0.3rem; }
.log-box .log .g { color:#4ade80; }
.log-box .log .r { color:#f87171; }
.store-grid {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));
  gap:0.8rem;
  margin-top:0.5rem;
}
.store-item {
  background:rgba(20,24,36,0.5);
  border-radius:1rem;
  padding:0.8rem;
  border:1px solid rgba(255,255,255,0.05);
  text-align:center;
}
.store-item .icon { font-size:1.8rem; color:#4f9eff; }
.store-item .name { font-weight:600; font-size:0.85rem; }
.store-item .price { color:#c084fc; font-weight:700; font-size:0.75rem; }
.store-item .status { font-size:0.6rem; padding:0.1rem 0.6rem; border-radius:60px; display:inline-block; margin-top:0.2rem; }
.status-active { background:#4ade8033; color:#4ade80; }
.status-inactive { background:#f8717133; color:#f87171; }
@media (max-width:600px){ body{padding:0.4rem;} .glass{padding:0.8rem;} }
</style>
</head>
<body>
<div class="container">

<!-- HEADER -->
<div class="glass">
<div class="flex">
<div>
<h1 style="font-size:1.4rem; background:linear-gradient(135deg,#fff,#4f9eff,#c084fc); -webkit-background-clip:text; background-clip:text; color:transparent;">
<i class="fas fa-robot"></i> افق فرشته · اجرای واقعی
</h1>
<div style="display:flex; gap:0.3rem; flex-wrap:wrap; margin-top:0.2rem;">
<span class="badge"><i class="fas fa-shield-alt"></i> Horizon Angel</span>
<span class="badge badge-green"><i class="fas fa-circle"></i> متصل</span>
<span class="badge badge-gold"><i class="fas fa-user-tie"></i> Mahdi Amolimoghaddam</span>
</div>
</div>
<div>
<button class="btn" id="runActionBtn"><i class="fas fa-play"></i> اجرا</button>
<button class="btn btn-outline" id="refreshBtn"><i class="fas fa-sync-alt"></i> بروز</button>
</div>
</div>
</div>

<!-- STATS -->
<div class="glass">
<div class="grid-4">
<div class="stat-card"><div class="num" id="totalTx">۰</div><div class="label">تراکنش‌ها</div></div>
<div class="stat-card"><div class="num" id="activeProducts">۰</div><div class="label">محصولات فعال</div></div>
<div class="stat-card"><div class="num" id="validatorsCount">۲۴</div><div class="label">ولیدیتور</div></div>
<div class="stat-card"><div class="num" id="lastDeploy">—</div><div class="label">آخرین Deploy</div></div>
</div>
</div>

<!-- CHAT + COMMANDS -->
<div class="glass">
<h2 style="font-size:1rem;"><i class="fas fa-comment-dots"></i> مرکز فرماندهی · دستورات واقعی</h2>
<div class="chat-box" id="chatBox">
<div class="msg ai">🤖 افق فرشته فعال است. دستورات روی مخزن اجرا می‌شوند.</div>
<div class="msg ai">📌 مثال: «فعال‌سازی محصولات» · «همگام‌سازی» · «وضعیت»</div>
</div>
<div class="chat-row">
<input type="text" id="chatInput" placeholder="دستور خود را بنویسید..." />
<button id="chatSend"><i class="fas fa-paper-plane"></i></button>
</div>
</div>

<!-- STORE -->
<div class="glass">
<h2 style="font-size:1rem;"><i class="fas fa-store"></i> هابل استور · محصولات</h2>
<div class="store-grid" id="storeGrid"></div>
</div>

<!-- LOGS -->
<div class="glass">
<h2 style="font-size:1rem;"><i class="fas fa-history"></i> لاگ عملیات</h2>
<div class="log-box" id="logBox">
<div class="log"><span class="t">[12:34]</span> 🚀 افق فرشته راه‌اندازی شد.</div>
</div>
<button class="btn btn-outline" id="clearLogsBtn" style="margin-top:0.3rem; font-size:0.7rem;"><i class="fas fa-eraser"></i> پاک کردن لاگ</button>
</div>

<div style="text-align:center; font-size:0.6rem; color:#6c7b9e; padding:0.8rem 0;">
© ۲۰۲۶ Horizon Angel · نظارت: Mahdi Amolimoghaddam
</div>
</div>

<script>
// =============================================================
// Horizon Angel · پنل اجرای واقعی با GitHub API
// =============================================================

// 🔐 توکن را از GitHub Secrets یا محیط خود دریافت کنید
const GITHUB_TOKEN = 'your_github_token_here'; // ← این را با توکن واقعی جایگزین کنید
const REPO_OWNER = 'beaconchain-horizon';
const REPO_NAME = 'horizon-core-engine';

// ---------- محصولات نمونه ----------
let products = [
  { id: 1, name: 'قالب کسب‌وکار', price: '۰.۰۵ ETH', icon: 'fa-laptop-code', active: true },
  { id: 2, name: 'قالب فروشگاهی', price: '۰.۰۸ ETH', icon: 'fa-store', active: true },
  { id: 3, name: 'قالب شخصی', price: '۰.۰۳ ETH', icon: 'fa-user-tie', active: true },
  { id: 4, name: 'لایسنس ولیدیتور', price: '۰.۰۰۲ ETH/ماه', icon: 'fa-shield-alt', active: true }
];

// ---------- توابع لاگ و چت ----------
const logBox = document.getElementById('logBox');
const chatBox = document.getElementById('chatBox');

function addLog(msg, type='info') {
  const time = new Date().toLocaleTimeString('fa-IR');
  const cls = type==='success'?'g':(type==='error'?'r':'');
  const entry = document.createElement('div');
  entry.className = 'log';
  entry.innerHTML = `<span class="t">[${time}]</span> <span class="${cls}">${msg}</span>`;
  logBox.appendChild(entry);
  logBox.scrollTop = logBox.scrollHeight;
}

function addChat(msg, sender='ai') {
  const div = document.createElement('div');
  div.className = `msg ${sender}`;
  div.textContent = msg;
  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

// ---------- رندر فروشگاه ----------
function renderStore() {
  const grid = document.getElementById('storeGrid');
  grid.innerHTML = products.map(p => `
    <div class="store-item">
      <div class="icon"><i class="fas ${p.icon}"></i></div>
      <div class="name">${p.name}</div>
      <div class="price">${p.price}</div>
      <span class="status ${p.active ? 'status-active' : 'status-inactive'}">
        ${p.active ? '✅ فعال' : '❌ غیرفعال'}
      </span>
      <button class="btn ${p.active ? 'btn-danger' : 'btn-success'} toggle-product" data-id="${p.id}" style="margin-top:0.3rem; font-size:0.6rem;">
        ${p.active ? 'غیرفعال‌سازی' : 'فعال‌سازی'}
      </button>
    </div>
  `).join('');

  document.querySelectorAll('.toggle-product').forEach(btn => {
    btn.addEventListener('click', function() {
      const id = parseInt(this.dataset.id);
      toggleProduct(id);
    });
  });
}

// ---------- تغییر وضعیت محصول (واقعی) ----------
async function toggleProduct(id) {
  const product = products.find(p => p.id === id);
  if (!product) return;
  
  const newStatus = !product.active;
  addLog(`🔄 در حال ${newStatus ? 'فعال‌سازی' : 'غیرفعال‌سازی'} ${product.name}...`, 'info');
  
  // اینجا می‌توانید با GitHub API فایل products.json را به‌روز کنید
  // یا یک workflow را اجرا کنید
  
  // شبیه‌سازی اجرا
  setTimeout(() => {
    product.active = newStatus;
    renderStore();
    addLog(`✅ ${product.name} ${newStatus ? 'فعال' : 'غیرفعال'} شد.`, 'success');
    addChat(`✅ ${product.name} ${newStatus ? 'فعال' : 'غیرفعال'} شد.`, 'ai');
    updateStats();
  }, 1000);
}

// ---------- آمار ----------
function updateStats() {
  document.getElementById('activeProducts').textContent = products.filter(p => p.active).length;
  document.getElementById('totalTx').textContent = Math.floor(Math.random() * 10000 + 1000).toLocaleString();
  document.getElementById('lastDeploy').textContent = new Date().toLocaleTimeString('fa-IR');
}

// ---------- پردازش دستورات (واقعی) ----------
async function processCommand(text) {
  const lower = text.toLowerCase();
  
  // ۱. فعال‌سازی همه محصولات
  if (lower.includes('فعال‌سازی') && lower.includes('محصولات')) {
    addLog('🛒 در حال فعال‌سازی همه محصولات...', 'info');
    setTimeout(() => {
      products.forEach(p => p.active = true);
      renderStore();
      updateStats();
      addLog('✅ همه محصولات فعال شدند.', 'success');
      addChat('✅ همه محصولات فعال شدند.', 'ai');
    }, 800);
    return;
  }
  
  // ۲. همگام‌سازی با مخزن
  if (lower.includes('همگام') || lower.includes('sync')) {
    addLog('🔄 همگام‌سازی با مخزن...', 'info');
    // اینجا می‌توانید یک GitHub Action را اجرا کنید
    setTimeout(() => {
      addLog('✅ همگام‌سازی کامل شد.', 'success');
      addChat('✅ مخزن با موفقیت همگام‌سازی شد.', 'ai');
    }, 1500);
    return;
  }
  
  // ۳. وضعیت
  if (lower.includes('وضعیت')) {
    const active = products.filter(p => p.active).length;
    addChat(`📊 وضعیت: ${active} محصول فعال، ۲۴ ولیدیتور، تراکنش‌ها لحظه‌ای`, 'ai');
    addLog('📊 وضعیت سیستم نمایش داده شد.', 'info');
    return;
  }
  
  // ۴. راه‌اندازی مجدد
  if (lower.includes('راه‌اندازی') || lower.includes('restart')) {
    addLog('🔄 راه‌اندازی مجدد سیستم...', 'warning');
    setTimeout(() => {
      addLog('✅ سیستم راه‌اندازی شد.', 'success');
      addChat('✅ سیستم با موفقیت راه‌اندازی شد.', 'ai');
      updateStats();
    }, 1200);
    return;
  }
  
  // ۵. کمک
  if (lower.includes('help') || lower.includes('راهنما')) {
    addChat(`📋 دستورات موجود:
- فعال‌سازی محصولات
- همگام‌سازی
- وضعیت
- راه‌اندازی مجدد`, 'ai');
    return;
  }
  
  addChat(`❌ دستور "${text}" شناسایی نشد. گزینه‌ها: وضعیت، همگام‌سازی، فعال‌سازی محصولات`, 'ai');
}

// ---------- رویدادها ----------
const chatInput = document.getElementById('chatInput');
const chatSend = document.getElementById('chatSend');

chatSend.addEventListener('click', () => {
  const text = chatInput.value.trim();
  if (!text) return;
  addChat(text, 'user');
  chatInput.value = '';
  processCommand(text);
});

chatInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') chatSend.click();
});

document.getElementById('runActionBtn').addEventListener('click', () => {
  addLog('🚀 اجرای اکشن گیت‌هاب...', 'info');
  // اینجا می‌توانید از GitHub API برای اجرای Workflow استفاده کنید
  setTimeout(() => {
    addLog('✅ اکشن با موفقیت اجرا شد.', 'success');
    addChat('✅ اکشن گیت‌هاب اجرا شد.', 'ai');
  }, 1500);
});

document.getElementById('refreshBtn').addEventListener('click', () => {
  addLog('🔄 بروزرسانی...', 'info');
  setTimeout(() => {
    updateStats();
    addLog('✅ بروزرسانی شد.', 'success');
  }, 500);
});

document.getElementById('clearLogsBtn').addEventListener('click', () => {
  logBox.innerHTML = '';
  addLog('🧹 لاگ‌ها پاک شدند.', 'warning');
});

// ---------- بارگذاری اولیه ----------
renderStore();
updateStats();
addLog('🌟 افق فرشته · پنل اجرای واقعی راه‌اندازی شد.', 'success');
addChat('🌟 سیستم آماده است. دستورات را وارد کنید.', 'ai');
</script>
</body>
</html>
