# Horizon Core Engine - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database
DB_PATH=./data/horizon.db

# License Enforcement (Commercial Lock)
LICENSE_ENFORCEMENT=true
LICENSE_KEY=your-license-key-here
LICENSE_SERVER_URL=https://your-license-server.com/verify

# Security
API_SECRET=your-super-secret-api-key
CSP_NONCE=true

# Blockchain / Validator Settings
VALIDATOR_TIMEOUT=30s
MAX_VALIDATORS=100000

# Merkle Tree / Prepaid API
MERKLE_TREE_DEPTH=16
DEFAULT_CREDITS=1000

# Logging
LOG_LEVEL=info
