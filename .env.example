# ============================================================
# Horizon Core Engine – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to the repository!
# ============================================================

# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://beaconchain:beaconchain123@localhost:5432/beaconchain?sslmode=disable

# External APIs
COINGECKO_API_KEY=your_coingecko_api_key_here
BEACONCHAIN_API_URL=https://api.beaconcha.in/api/v1
BEACONCHAIN_API_KEY=your_beaconchain_api_key_here
INFURA_PROJECT_ID=your_infura_project_id_here

# Security (optional)
ECDSA_PRIVATE_KEY=your_base64_ecdsa_private_key_here
MERKLE_SALT=your_secure_random_salt_here

# Webhook & GitHub (optional)
WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your_github_personal_access_token_here

# Prefect Cloud (optional)
PREFECT_API_KEY=your_prefect_api_key_here
PREFECT_WORKSPACE=beaconchain/prod
